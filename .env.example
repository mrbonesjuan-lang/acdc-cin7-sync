# Cin7 Omni API credentials
CIN7_API_USER=Juan Test API
CIN7_API_KEY=14b200c01185420b87d731d72575c898

# PostgreSQL connection (Render gives you this automatically when you
# create a free PostgreSQL database - copy the "Internal Database URL"
# or "External Database URL" here)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# How often to pull new data from Cin7, in minutes
SYNC_INTERVAL_MINUTES=15

# Port for the health-check web server (Render sets this automatically,
# you usually don't need to change it)
PORT=3000
